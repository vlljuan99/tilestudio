# --- Payload ---
# Secret usado para firmar JWTs y sesiones de admin. Generar con: openssl rand -base64 32
PAYLOAD_SECRET=change-me-to-a-long-random-string

# URL pública del sitio (usada por Payload para links absolutos en admin)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Base de datos ---
# Dev local: SQLite (zero-config). Producción: cambiar adapter a @payloadcms/db-postgres
# y poner DATABASE_URL=postgres://user:pass@host:5432/dbname
DATABASE_URI=file:./tilestudio.db

# --- IA: Simulador de habitaciones ---
# Proveedor activo (auto | gemini | openai | mock). Por defecto "auto": usa Gemini si
# hay GOOGLE_API_KEY, si no OpenAI, si no Mock.
# AI_PROVIDER=gemini

# Google Gemini (recomendado — ~4× más barato y ~6× más rápido que gpt-image-1)
# Obtén tu key gratuita en: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=AIza...

# OpenAI (fallback para el simulador, o forzado con AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# --- IA: Importador de PDF (visión + extracción de datos) ---
# Proveedor activo (auto | gemini | openai). Por defecto "auto": usa Gemini si hay
# GOOGLE_API_KEY, si no OpenAI. Gemini 2.5 Flash es ~5× más barato y mejor en bbox.
# AI_VISION_PROVIDER=gemini

# Modelo de visión opcional (por defecto: gemini-2.5-flash-preview-05-20 / gpt-4o-mini)
# AI_VISION_MODEL=gemini-2.5-flash-preview-05-20

# --- Email transaccional (Fase 2) ---
# RESEND_API_KEY=re_...
# EMAIL_FROM=Tilestudio <hola@tudominio.es>

# --- Almacenamiento (Producción) ---
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=auto
# S3_ENDPOINT=
